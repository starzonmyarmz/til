---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "TIL", description } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🤔</text></svg>"
    />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={title}
      href={`${base}rss.xml`}
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <h1><a href={base}>🤔 Today I Learned</a></h1>
        <p class="tag">
          Things Claude changed that I didn't understand — explained… by Claude.
        </p>
      </header>
      <slot />
      <footer class="site-footer">
        <a href="https://github.com/starzonmyarmz/til">Source</a>
        <span aria-hidden="true"> · </span>
        <a
          href="https://github.com/starzonmyarmz/dotfiles/tree/main/claude/.claude/skills/til"
          ><code>/til</code> skill</a
        >
        <span aria-hidden="true"> · </span>
        <a href={`${base}rss.xml`}>RSS</a>
      </footer>
    </div>
  </body>
</html>
